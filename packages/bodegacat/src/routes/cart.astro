---
import CartPage from '@components/CartPage';
import Navbar from '@components/Navbar';
import { getEffectiveConfig } from '@config/site';
import Layout from '@layouts/Layout.astro';
import { env } from 'cloudflare:workers';

const siteConfig = await getEffectiveConfig(env.SETTINGS_KV);
---

<Layout title="Shopping Cart" siteConfig={siteConfig}>
  <Navbar siteConfig={siteConfig} client:load />

  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <CartPage client:load />
  </div>
</Layout>
