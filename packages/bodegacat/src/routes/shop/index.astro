---
export const prerender = true;

import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar';
import { getSiteConfig } from '@config/site';
import { getTranslations, formatPrice } from '@i18n';
import { getProducts } from '@lib/stripe';
import { publicProductPath } from '@lib/catalog-paths';

const siteConfig = getSiteConfig();
const t = getTranslations(siteConfig.locale);

const products = await getProducts({ includeUnpublished: false });

const categories = [
  ...new Set(products.map((p) => p.metadata.category).filter(Boolean)),
];
const tags = [...new Set(products.flatMap((p) => p.metadata.tags))];
---

<Layout title={t.shop.title} siteConfig={siteConfig}>
  <Navbar siteConfig={siteConfig} client:load />

  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="mb-4 text-3xl font-bold">{t.shop.title}</h1>
      <p class="text-muted">{siteConfig.shopTagline}</p>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <div class="card sticky top-8">
          <h3 class="mb-4 text-lg font-semibold">{t.shop.filters}</h3>

          <div class="mb-6">
            <label class="mb-2 block text-sm font-medium">
              Search
              <input
                type="text"
                id="search"
                placeholder={t.shop.search}
                class="input"
              />
            </label>
          </div>

          {
            categories.length > 0 && (
              <div class="mb-6">
                <h4 class="mb-3 font-medium">{t.shop.categories}</h4>
                <div class="space-y-2">
                  {categories.map((category) => (
                    <label class="flex items-center">
                      <input type="checkbox" class="mr-2" />
                      <span class="text-sm">{category}</span>
                    </label>
                  ))}
                </div>
              </div>
            )
          }

          {
            tags.length > 0 && (
              <div class="mb-6">
                <h4 class="mb-3 font-medium">{t.shop.tags}</h4>
                <div class="space-y-2">
                  {tags.map((tag) => (
                    <label class="flex items-center">
                      <input type="checkbox" class="mr-2" />
                      <span class="text-sm">{tag}</span>
                    </label>
                  ))}
                </div>
              </div>
            )
          }

          <div class="mb-6">
            <h4 class="mb-3 font-medium">{t.shop.priceRange}</h4>
            <div class="space-y-2">
              <input type="range" min="0" max="1000" class="w-full" />
              <div class="text-muted flex justify-between text-sm">
                <span
                  >{
                    formatPrice(0, siteConfig.currency, siteConfig.locale)
                  }</span
                >
                <span
                  >{
                    formatPrice(100000, siteConfig.currency, siteConfig.locale)
                  }</span
                >
              </div>
            </div>
          </div>

          <button class="btn btn-outline w-full">{t.shop.clearFilters}</button>
        </div>
      </div>

      <div class="lg:col-span-3">
        {
          products.length > 0 ? (
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
              {products.map((product) => (
                <div class="card transition-shadow hover:shadow-lg">
                  {product.images.length > 0 && (
                    <Image
                      src={product.images[0]}
                      alt={product.name}
                      width={400}
                      height={192}
                      class="mb-4 h-48 w-full rounded-t-lg object-cover"
                    />
                  )}
                  <h3 class="mb-2 text-lg font-semibold">{product.name}</h3>
                  <p class="text-muted mb-4 line-clamp-2">
                    {product.description}
                  </p>

                  {product.metadata.tags.length > 0 && (
                    <div class="mb-4 flex flex-wrap gap-1">
                      {product.metadata.tags.slice(0, 3).map((tag) => (
                        <span class="bg-primary/10 text-primary rounded px-2 py-1 text-xs">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <div class="flex items-center justify-between">
                    <span class="text-primary text-xl font-bold">
                      {formatPrice(
                        product.basePrice,
                        product.currency || siteConfig.currency,
                        siteConfig.locale,
                      )}
                    </span>
                    <a
                      href={publicProductPath(product.slug)}
                      class="btn btn-primary">
                      {t.shop.viewDetails}
                    </a>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="py-12 text-center">
              <p class="text-muted text-lg">{t.shop.noProducts}</p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</Layout>

<script>
  // Client-side filtering logic will go here
</script>
