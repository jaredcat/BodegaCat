---
/**
 * Public product detail — prerendered at build from published Stripe products.
 * Rebuild (or webhook → build hook) when catalog changes.
 */
export const prerender = true;

import Navbar from '@components/Navbar';
import Layout from '@layouts/Layout.astro';
import ProductDetailInner from '../_partials/ProductDetailInner.astro';
import { getSiteConfig } from '@config/site';
import { getProduct, getProducts } from '@lib/stripe';

export async function getStaticPaths() {
  const products = await getProducts({ includeUnpublished: false });
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/shop');
}

const siteConfig = getSiteConfig();
const product = await getProduct(slug, { includeUnpublished: false });
if (!product) {
  return Astro.redirect('/shop');
}
---

<Layout title={product.name} description={product.description} siteConfig={siteConfig}>
  <Navbar siteConfig={siteConfig} client:load />
  <ProductDetailInner product={product} siteConfig={siteConfig} />
</Layout>
