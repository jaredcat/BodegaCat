---
export const prerender = false;

import AdminNav from '@components/AdminNav';
import { DevIndicator } from '@components/DevIndicator';
import ProductForm from '@components/ProductForm';
import { getEffectiveConfig } from '@config/site';
import Layout from '@layouts/Layout.astro';
import { getProducts, hasUnpublishedDrafts } from '@lib/stripe';
import type { Product } from '@models/product';
import { env } from 'cloudflare:workers';

const siteConfig = await getEffectiveConfig(env.SETTINGS_KV);
const catalogAll = await getProducts({ includeUnpublished: true });
const hasUnpublishedProducts = hasUnpublishedDrafts(catalogAll);
---

<Layout title="Add New Product">
  <div class="min-h-screen bg-gray-50">
    <!-- Development Mode Indicator -->
    <DevIndicator
      isDevelopment={Astro.locals.user?.isDevelopment}
      localPreviewBypass={Astro.locals.user?.localPreviewBypass}
      client:load
    />
    <AdminNav
      client:load
      currentPage="new"
      hasUnpublishedProducts={hasUnpublishedProducts}
    />

    <!-- Admin Header -->
    <header class="bg-white shadow">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between py-6">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">Add New Product</h1>
            <p class="text-gray-600">Create a new product for your store</p>
          </div>
          <a href="/admin/products" class="btn btn-outline">
            Back to Products
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
      <ProductForm
        productTypes={siteConfig.productTypes}
        onSubmit={async (productData: Partial<Product>) => {
          const res = await fetch('/api/admin/products', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(productData),
          });
          const body = (await res.json()) as {
            error?: string;
            product?: { metadata?: { slug?: string } };
          };
          if (!res.ok) {
            throw new Error(body.error ?? 'Failed to create product');
          }
          const slug = body.product?.metadata?.slug;
          const isDraft = productData.metadata?.publishedToStorefront === false;
          if (isDraft && typeof slug === 'string' && slug.length > 0) {
            window.location.href = `/preview/shop/${slug}`;
          } else {
            window.location.href = '/admin/products';
          }
        }}
        onCancel={() => {
          window.location.href = '/admin/products';
        }}
        client:load
      />
    </main>
  </div>
</Layout>
