---
import { getSiteConfig } from '@config/site';
import '@styles/global.css';
import Cart from '../components/Cart';
import type { PreviewProductContext } from '../components/StorefrontPreviewBanner.tsx';
import StorefrontPreviewBanner from '../components/StorefrontPreviewBanner.tsx';
import type { SiteConfig } from '../types/product';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Pass siteConfig from SSR pages (e.g. admin/preview with KV); public SSG pages omit and use build-time config. */
  siteConfig?: SiteConfig;
  /** If false, render using the default theme variables (useful for admin pages). */
  useSiteTheme?: boolean;
  /** Set on `/preview/*` draft storefront (SSR, staff-only). */
  storefrontPreview?: boolean;
  /** On `/shop/[slug]` in preview, enables “Publish” for draft products. */
  previewProduct?: PreviewProductContext | null;
  /**
   * Pass `true` when any product has `bodegacat_published=false` (draft on storefront).
   * Controls “Back to admin” on the preview banner; omit/false when catalog matches live.
   */
  previewCatalogHasDraftProducts?: boolean;
}

const {
  title,
  description,
  siteConfig: propSiteConfig,
  useSiteTheme = true,
  storefrontPreview = false,
  previewProduct = null,
  previewCatalogHasDraftProducts = false,
} = Astro.props;

/** Leave draft preview and open the public (prerendered) storefront. */
const previewBannerExitHref = '/';
// SSR routes pass KV-loaded config; public SSG pages fall back to build-time `getSiteConfig()`.
const siteConfig = propSiteConfig ?? getSiteConfig();
const themeSiteConfig = useSiteTheme ? siteConfig : getSiteConfig();
const pageDescription = description ?? siteConfig.description;
const lang = siteConfig.locale.split('-')[0];

// Build the CSS variable block from the active theme.
// Any custom variables added by third-party themes are automatically included.
const activeThemeVars = Object.entries(themeSiteConfig.theme.variables)
  .map(([k, v]) => `  ${k}: ${String(v)};`)
  .join('\n');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={siteConfig.favicon ?? '/favicon.svg'}
    />
    <title>{title} — {siteConfig.name}</title>

    <!-- Theme CSS variables -->
    <style set:html={`:root {\n${activeThemeVars}\n}`}></style>

    <!-- Optional theme-provided CSS (fonts, animations, etc.) -->
    {
      useSiteTheme && siteConfig.theme.css && (
        <style set:html={siteConfig.theme.css} />
      )
    }
  </head>
  <body>
    {
      storefrontPreview && (
        <StorefrontPreviewBanner
          client:load
          exitHref={previewBannerExitHref}
          previewProduct={previewProduct}
          catalogHasDraftProducts={previewCatalogHasDraftProducts}
        />
      )
    }
    <slot />
    <Cart client:only="react" />
  </body>
</html>
