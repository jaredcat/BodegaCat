---
import { getSiteConfig } from '@config/site';
import '@styles/global.css';
import Cart from '../components/Cart';
import StorefrontPreviewBanner from '../components/StorefrontPreviewBanner.astro';
import type { SiteConfig } from '../types/product';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Pass the already-loaded siteConfig from SSR pages so KV theme overrides are applied. */
  siteConfig?: SiteConfig;
  /** If false, render using the default theme variables (useful for admin pages). */
  useSiteTheme?: boolean;
  /** Set when `/` or `/shop` runs in preview mode (`?preview=1` + Access in production). */
  storefrontPreview?: boolean;
}

const {
  title,
  description,
  siteConfig: propSiteConfig,
  useSiteTheme = true,
  storefrontPreview = false,
} = Astro.props;
// SSR pages pass their KV-loaded config; prerendered pages fall back to the build-time config.
const siteConfig = propSiteConfig ?? getSiteConfig();
const themeSiteConfig = useSiteTheme ? siteConfig : getSiteConfig();
const pageDescription = description ?? siteConfig.description;
const lang = siteConfig.locale.split('-')[0];

// Build the CSS variable block from the active theme.
// Any custom variables added by third-party themes are automatically included.
const activeThemeVars = Object.entries(themeSiteConfig.theme.variables)
  .map(([k, v]) => `  ${k}: ${String(v)};`)
  .join('\n');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={siteConfig.favicon ?? '/favicon.svg'} />
    <title>{title} — {siteConfig.name}</title>

    <!-- Theme CSS variables -->
    <style set:html={`:root {\n${activeThemeVars}\n}`} />

    <!-- Optional theme-provided CSS (fonts, animations, etc.) -->
    {useSiteTheme && siteConfig.theme.css && <style set:html={siteConfig.theme.css} />}
  </head>
  <body>
    {storefrontPreview && <StorefrontPreviewBanner />}
    <slot />
    <Cart client:only="react" />
  </body>
</html>
