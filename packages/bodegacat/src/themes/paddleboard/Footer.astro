---
/**
 * Paddleboard theme Footer component.
 *
 * Dark footer (--color-footer-bg) with site name, description, quick links,
 * social links, and a contact email. Matches the anybodypaddlesports.com footer.
 *
 * Usage:
 *   import Footer from '../themes/paddleboard/Footer.astro';
 *   <Footer siteConfig={siteConfig} t={t} copyrightYear={new Date().getFullYear()} />
 */

import type { Translations } from '../../i18n';
import type { SiteConfig } from '../../types/product';

interface Props {
  siteConfig: SiteConfig;
  t: Translations;
  copyrightYear?: number;
}

const { siteConfig, t, copyrightYear = new Date().getFullYear() } = Astro.props;

/** Canonical repo link for the “Powered by” attribution (not user-controlled). */
const bodegaCatRepoUrl = "https://github.com/bodegacat/bodegacat";
---

<footer class="site-footer py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <h3 class="mb-4 text-xl font-bold">{siteConfig.name}</h3>
        <p class="text-muted mb-4 max-w-sm">{siteConfig.description}</p>
        {
          siteConfig.contactEmail && (
            <a
              href={`mailto:${siteConfig.contactEmail}`}
              class="text-muted hover:text-primary text-sm">
              {siteConfig.contactEmail}
            </a>
          )
        }
      </div>

      <!-- Quick Links -->
      {
        siteConfig.footerLinks.length > 0 && (
          <div>
            <h4 class="mb-4 text-lg font-semibold">{t.footer.quickLinks}</h4>
            <ul class="space-y-2">
              {siteConfig.footerLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-muted hover:text-primary transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Social Links -->
      {
        siteConfig.socialLinks.length > 0 && (
          <div>
            <h4 class="mb-4 text-lg font-semibold">Follow Us</h4>
            <ul class="space-y-2">
              {siteConfig.socialLinks.map((link) => (
                <li>
                  <a
                    href={link.url}
                    class="text-muted hover:text-primary transition-colors"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={link.label ?? link.platform}>
                    {link.label ?? link.platform}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <div
      class="text-muted mt-8 border-t pt-8 text-center"
      style="border-color: var(--color-footer-border)">
      &copy; {copyrightYear}
      {siteConfig.name}. {t.footer.allRightsReserved} | {t.footer.poweredByPrefix}{' '}
      <a
        href={bodegaCatRepoUrl}
        class="text-muted hover:text-primary transition-colors"
        target="_blank"
        rel="noopener noreferrer">
        {t.footer.bodegaCatBrand}
      </a>
    </div>
  </div>
</footer>
