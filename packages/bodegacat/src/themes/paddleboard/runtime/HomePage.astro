---
import type { Translations } from '../../../i18n';
import type { SiteConfig } from '../../../types/product';

import CTASection from '../CTASection.astro';
import FeatureGrid from '../FeatureGrid.astro';
import Footer from '../Footer.astro';
import Hero from '../Hero.astro';

interface Props {
  siteConfig: SiteConfig;
  t: Translations;
  copyrightYear: number;
  catalogShopHref?: string;
}

const { siteConfig, t, copyrightYear, catalogShopHref = '/shop' } = Astro.props;

const defaultHeroTitle = `Welcome to ${siteConfig.name}`;
const heroTitle: string = siteConfig.homeHeadline ?? defaultHeroTitle;
---

<Hero
  title={heroTitle}
  description={siteConfig.description}
  ctaHref={catalogShopHref}
  ctaText={t.shop.shopNow}
/>

<FeatureGrid
  heading={siteConfig.aboutTitle}
  subheading={siteConfig.aboutText}
  features={[
    {
      title: 'Safety First',
      description: 'Trusted checkout, clear policies, and reliable support.',
      icon: '🛟',
      accentColor: 'primary',
    },
    {
      title: 'Fast & Simple',
      description:
        'A streamlined shopping experience that gets out of your way.',
      icon: '⚡',
      accentColor: 'accent',
    },
    {
      title: 'Built for Adventure',
      description: 'Designed to look great on mobile and desktop.',
      icon: '🌊',
      accentColor: 'primary',
    },
  ]}
/>

<CTASection
  title="Ready for your next adventure?"
  description="Browse the shop and find something you’ll love."
  buttonText={t.shop.shopNow}
  buttonHref={catalogShopHref}
/>

<Footer siteConfig={siteConfig} t={t} copyrightYear={copyrightYear} />
