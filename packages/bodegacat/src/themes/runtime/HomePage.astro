---
import type { SiteConfig } from '../../types/product';
import type { Translations } from '../../i18n';

import PaddleboardHomePage from '../paddleboard/runtime/HomePage.astro';

interface Props {
  siteConfig: SiteConfig;
  t: Translations;
  copyrightYear: number;
  /** Public `/shop` or draft preview `/preview/shop`. */
  catalogShopHref?: string;
}

const { siteConfig, t, copyrightYear, catalogShopHref = '/shop' } = Astro.props;

// Built-in theme routing lives here (theme layer), not in core pages.
const isPaddleboard = siteConfig.theme.id === 'paddleboard';
---

{isPaddleboard ? (
  <PaddleboardHomePage
    siteConfig={siteConfig}
    t={t}
    copyrightYear={copyrightYear}
    catalogShopHref={catalogShopHref}
  />
) : (
  <slot />
)}

