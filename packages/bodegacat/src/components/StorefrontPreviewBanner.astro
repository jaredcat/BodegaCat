---
/**
 * Shown when `?preview=1` (and cookie) enables storefront preview mode.
 * Exit: link to same path with `?preview=0` or visit any URL with `?preview=0`.
 */
const pathname = Astro.url.pathname;
const search = Astro.url.searchParams;
const exitParams = new URLSearchParams(search);
exitParams.set('preview', '0');
const exitHref = `${pathname}?${exitParams.toString()}`;
---

<div
  class="border-b border-cyan-700 bg-cyan-600 px-4 py-2 text-center text-sm text-white shadow-md"
  role="status">
  <span class="font-medium">Storefront preview</span>
  — showing unpublished products.{' '}
  <a href={exitHref} class="underline decoration-white/80 hover:decoration-white">
    Exit preview
  </a>
</div>
