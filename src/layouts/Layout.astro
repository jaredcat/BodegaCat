---
import { getSiteConfig } from '@config/site';
import '@styles/global.css';
import Cart from '../components/Cart';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description } = Astro.props;
const siteConfig = getSiteConfig();
const pageDescription = description ?? siteConfig.description;
const lang = siteConfig.locale.split('-')[0];

// Build the CSS variable block from the active theme.
// Any custom variables added by third-party themes are automatically included.
const themeVars = Object.entries(siteConfig.theme.variables)
  .map(([k, v]) => `  ${k}: ${v};`)
  .join('\n');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={siteConfig.favicon ?? '/favicon.svg'} />
    <title>{title} — {siteConfig.name}</title>

    <!-- Theme CSS variables -->
    <style set:html={`:root {\n${themeVars}\n}`} />

    <!-- Optional theme-provided CSS (fonts, animations, etc.) -->
    {siteConfig.theme.css && <style set:html={siteConfig.theme.css} />}
  </head>
  <body>
    <slot />
    <Cart client:only="react" />
  </body>
</html>
