{
  "name": "bodegacat",
  "type": "module",
  "version": "1.0.0",
  "description": "A simple, fast, and configurable e-commerce store built with Astro",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:with-products": "node scripts/build-with-products.js",
    "test:stripe": "node scripts/test-stripe.js",
    "setup:stripe": "node scripts/setup-stripe-products.js",
    "preview": "pnpm -s astro build && wrangler dev --local --config dist/server/wrangler.json",
    "preview:simple": "astro preview",
    "deploy": "pnpm -s astro build && wrangler deploy --config dist/server/wrangler.json",
    "astro": "astro",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.4",
    "@astrojs/react": "^5.0.2",
    "@astrojs/ts-plugin": "^1.10.7",
    "@heroicons/react": "^2.2.0",
    "@nanostores/react": "^1.1.0",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.1",
    "nanostores": "^1.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^21.0.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "node-gyp": "^12.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "wrangler": "^4.78.0"
  },
  "keywords": [
    "ecommerce",
    "astro",
    "stripe",
    "static-site",
    "shop",
    "store"
  ],
  "author": "Jaredcat",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
